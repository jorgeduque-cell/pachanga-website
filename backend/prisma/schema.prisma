generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum TableZone {
  SALON
  TERRAZA
  VIP
  BARRA
  PISTA
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  name         String
  passwordHash String         @map("password_hash")
  role         UserRole       @default(STAFF)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]

  @@map("users")
}

model Table {
  id           String      @id @default(uuid())
  name         String      @unique
  capacity     Int
  zone         TableZone
  floor        Int         @default(1)
  posX         Int         @default(0) @map("pos_x")
  posY         Int         @default(0) @map("pos_y")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  reservations Reservation[]

  @@index([floor, zone])
  @@map("tables")
}

model Reservation {
  id              String            @id @default(uuid())
  customerName    String            @map("customer_name")
  customerPhone   String            @map("customer_phone")
  reservationDate DateTime          @map("reservation_date") @db.Date
  reservationTime String            @map("reservation_time")
  partySize       Int               @map("party_size")
  message         String?
  status          ReservationStatus @default(PENDING)
  tableId         String?           @map("table_id")
  table           Table?            @relation(fields: [tableId], references: [id])
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([reservationDate, status])
  @@index([tableId, reservationDate])
  @@map("reservations")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model TokenBlacklist {
  id        String   @id @default(uuid())
  tokenId   String   @unique @map("token_id")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("token_blacklist")
}

// ═══════════════════════════════════════════════════════════
// CRM & FIDELIZACIÓN
// ═══════════════════════════════════════════════════════════

enum CustomerSource {
  QR_SCAN
  RESERVATION
  MANUAL
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageType {
  WELCOME
  BIRTHDAY
  PROMO
  REACTIVATION
}

model Customer {
  id          String         @id @default(uuid())
  name        String
  phone       String         @unique
  birthDate   DateTime?      @map("birth_date") @db.Date
  rating      Int?
  source      CustomerSource @default(QR_SCAN)
  totalVisits Int            @default(1) @map("total_visits")
  lastVisitAt DateTime       @default(now()) @map("last_visit_at")
  optIn       Boolean        @default(true) @map("opt_in")
  notes       String?
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  messages     WhatsAppMessage[]
  interactions Interaction[]

  @@index([phone])
  @@index([birthDate])
  @@index([lastVisitAt])
  @@map("customers")
}

model Interaction {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id])
  type       String
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([customerId])
  @@index([createdAt])
  @@map("interactions")
}

model WhatsAppMessage {
  id           String        @id @default(uuid())
  customerId   String        @map("customer_id")
  customer     Customer      @relation(fields: [customerId], references: [id])
  type         MessageType
  templateName String        @map("template_name")
  status       MessageStatus @default(QUEUED)
  waMessageId  String?       @map("wa_message_id")
  sentAt       DateTime?     @map("sent_at")
  deliveredAt  DateTime?     @map("delivered_at")
  readAt       DateTime?     @map("read_at")
  errorCode    String?       @map("error_code")
  createdAt    DateTime      @default(now()) @map("created_at")

  @@index([customerId])
  @@index([type, status])
  @@index([sentAt])
  @@map("whatsapp_messages")
}

model CrmConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("crm_config")
}
