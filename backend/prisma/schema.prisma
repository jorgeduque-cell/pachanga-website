generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum TableZone {
  SALON
  TERRAZA
  VIP
  BARRA
  PISTA
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  name         String
  passwordHash String         @map("password_hash")
  role         UserRole       @default(STAFF)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]

  @@map("users")
}

model Table {
  id           String      @id @default(uuid())
  name         String      @unique
  capacity     Int
  zone         TableZone
  floor        Int         @default(1)
  posX         Int         @default(0) @map("pos_x")
  posY         Int         @default(0) @map("pos_y")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  reservations Reservation[]

  @@index([floor, zone])
  @@map("tables")
}

model Reservation {
  id              String            @id @default(uuid())
  customerName    String            @map("customer_name")
  customerPhone   String            @map("customer_phone")
  reservationDate DateTime          @map("reservation_date") @db.Date
  reservationTime String            @map("reservation_time")
  partySize       Int               @map("party_size")
  message         String?
  status          ReservationStatus @default(PENDING)
  tableId         String?           @map("table_id")
  table           Table?            @relation(fields: [tableId], references: [id])
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([reservationDate, status])
  @@index([tableId, reservationDate])
  @@map("reservations")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model TokenBlacklist {
  id        String   @id @default(uuid())
  tokenId   String   @unique @map("token_id")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("token_blacklist")
}

// ═══════════════════════════════════════════════════════════
// CRM & FIDELIZACIÓN
// ═══════════════════════════════════════════════════════════

enum CustomerSource {
  QR_SCAN
  RESERVATION
  MANUAL
  WHATSAPP_CHAT
}

enum ConversationStatus {
  ACTIVE
  ESCALATED
  RESOLVED
}

enum ChatMessageRole {
  CUSTOMER
  BOT
  ADMIN
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  DEAD_LETTER
}

enum MessageType {
  WELCOME
  BIRTHDAY
  PROMO
  REACTIVATION
  SURVEY
}

model Customer {
  id          String         @id @default(uuid())
  name        String
  phone       String         @unique
  birthDate   DateTime?      @map("birth_date") @db.Date
  rating      Int?
  source      CustomerSource @default(QR_SCAN)
  totalVisits Int            @default(1) @map("total_visits")
  lastVisitAt DateTime       @default(now()) @map("last_visit_at")
  optIn       Boolean        @default(true) @map("opt_in")
  notes       String?
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  messages             WhatsAppMessage[]
  interactions         Interaction[]
  surveys              SatisfactionSurvey[]
  conversations        ChatConversation[]
  paymentVerifications PaymentVerification[]

  @@index([phone])
  @@index([birthDate])
  @@index([lastVisitAt])
  @@map("customers")
}

model Interaction {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id])
  type       String
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([customerId])
  @@index([createdAt])
  @@map("interactions")
}

model WhatsAppMessage {
  id           String        @id @default(uuid())
  customerId   String        @map("customer_id")
  customer     Customer      @relation(fields: [customerId], references: [id])
  type         MessageType
  templateName String        @map("template_name")
  status       MessageStatus @default(QUEUED)
  waMessageId  String?       @map("wa_message_id")
  sentAt       DateTime?     @map("sent_at")
  deliveredAt  DateTime?     @map("delivered_at")
  readAt       DateTime?     @map("read_at")
  errorCode    String?       @map("error_code")
  retryCount   Int           @default(0) @map("retry_count")
  lastRetryAt  DateTime?     @map("last_retry_at")
  createdAt    DateTime      @default(now()) @map("created_at")

  @@index([customerId])
  @@index([type, status])
  @@index([sentAt])
  @@map("whatsapp_messages")
}

model CrmConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("crm_config")
}

// ═══════════════════════════════════════════════════════════
// ENCUESTAS DE SATISFACCIÓN
// ═══════════════════════════════════════════════════════════

model SatisfactionSurvey {
  id             String   @id @default(uuid())
  customerId     String   @map("customer_id")
  customer       Customer @relation(fields: [customerId], references: [id])
  musicRating    Int      @map("music_rating")
  serviceRating  Int      @map("service_rating")
  ambienceRating Int      @map("ambience_rating")
  hygieneRating  Int      @map("hygiene_rating")
  qrTable        String?  @map("qr_table")
  comments       String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([customerId])
  @@index([createdAt])
  @@map("satisfaction_surveys")
}

// ═══════════════════════════════════════════════════════════
// CHATBOT IA
// ═══════════════════════════════════════════════════════════

model ChatConversation {
  id          String             @id @default(uuid())
  customerId  String             @map("customer_id")
  customer    Customer           @relation(fields: [customerId], references: [id])
  status      ConversationStatus @default(ACTIVE)
  intent      String?
  metadata    Json?
  escalatedAt DateTime?          @map("escalated_at")
  resolvedAt  DateTime?          @map("resolved_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  messages              ChatMessage[]
  paymentVerifications  PaymentVerification[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("chat_conversations")
}

// ═══════════════════════════════════════════════════════════
// PAYMENT VERIFICATION
// ═══════════════════════════════════════════════════════════

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
  EXPIRED
}

model PaymentVerification {
  id              String        @id @default(uuid())
  reference       String        @unique
  customerId      String        @map("customer_id")
  customer        Customer      @relation(fields: [customerId], references: [id])
  eventId         String        @map("event_id")
  event           Event         @relation(fields: [eventId], references: [id])
  conversationId  String        @map("conversation_id")
  conversation    ChatConversation @relation(fields: [conversationId], references: [id])
  ticketType      String        @map("ticket_type")
  quantity        Int
  expectedAmount  Int           @map("expected_amount")
  detectedAmount  Int?          @map("detected_amount")
  receiptUrl      String?       @map("receipt_url")
  visionAnalysis  Json?         @map("vision_analysis")
  status          PaymentStatus @default(PENDING)
  adminNotes      String?       @map("admin_notes")
  confirmedBy     String?       @map("confirmed_by")
  confirmedAt     DateTime?     @map("confirmed_at")
  rejectedAt      DateTime?     @map("rejected_at")
  expiresAt       DateTime      @map("expires_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([eventId])
  @@index([status])
  @@index([expiresAt])
  @@map("payment_verifications")
}

model ChatMessage {
  id              String           @id @default(uuid())
  conversationId  String           @map("conversation_id")
  conversation    ChatConversation @relation(fields: [conversationId], references: [id])
  role            ChatMessageRole
  content         String
  intent          String?
  confidence      Float?
  waMessageId     String?          @map("wa_message_id")
  metadata        Json?
  createdAt       DateTime         @default(now()) @map("created_at")

  @@index([conversationId])
  @@index([createdAt])
  @@map("chat_messages")
}

model ChatbotKnowledge {
  id        String   @id @default(uuid())
  category  String
  key       String
  value     String
  isActive  Boolean  @default(true) @map("is_active")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([category, key])
  @@index([category])
  @@map("chatbot_knowledge")
}

// ═══════════════════════════════════════════════════════════
// EVENTOS
// ═══════════════════════════════════════════════════════════

enum EventStatus {
  ACTIVE
  SOLD_OUT
  CANCELLED
  PAST
}

model Event {
  id          String      @id @default(uuid())
  name        String
  eventDate   DateTime    @map("event_date") @db.Date
  eventTime   String      @map("event_time")
  description String?
  coverPrice  Int?        @map("cover_price")
  flyerUrl    String?     @map("flyer_url")
  status      EventStatus @default(ACTIVE)
  isActive    Boolean     @default(true) @map("is_active")
  isFeatured  Boolean     @default(false) @map("is_featured")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  tables      EventTable[]
  paymentVerifications PaymentVerification[]

  @@index([eventDate, status])
  @@map("events")
}

model EventTable {
  id       String    @id @default(uuid())
  eventId  String    @map("event_id")
  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  zone     TableZone
  total    Int       @default(0)
  reserved Int       @default(0)

  @@unique([eventId, zone])
  @@map("event_tables")
}
