# ============================================
# Backend - Variables de Entorno
# ============================================

# Base de datos (PostgreSQL en Render)
DATABASE_URL=postgresql://usuario:password@host:puerto/dbname?schema=public

# JWT Secret (mínimo 64 caracteres en producción)
JWT_SECRET=tu_secreto_muy_largo_y_seguro_de_al_menos_64_caracteres_para_produccion

# Puerto (Render usa generalmente 10000)
PORT=3001

# Entorno
NODE_ENV=production

# URL del frontend (para CORS y QR)
FRONTEND_URL=https://pachanga-frontend.vercel.app
CORS_ORIGIN=https://pachanga-frontend.vercel.app,https://pachanga-admin.vercel.app

# ============================================
# WhatsApp Cloud API (opcional)
# ============================================
WHATSAPP_TOKEN=tu_token_de_whatsapp
WHATSAPP_PHONE_ID=tu_phone_id
WHATSAPP_BUSINESS_ID=tu_business_id
WHATSAPP_VERIFY_TOKEN=pachanga_webhook_2026
WHATSAPP_API_VERSION=v21.0
WHATSAPP_DRY_RUN=false
