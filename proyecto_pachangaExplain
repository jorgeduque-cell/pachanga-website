## Base de Datos (10 modelos)

```mermaid
erDiagram
    User ||--o{ RefreshToken : "tiene"
    Table ||--o{ Reservation : "tiene"
    Customer ||--o{ Interaction : "tiene"
    Customer ||--o{ WhatsAppMessage : "recibe"
    Customer ||--o{ SatisfactionSurvey : "completa"

    User {
        uuid id PK
        string email UK
        string name
        string passwordHash
        enum role "ADMIN | STAFF"
    }

    Table {
        uuid id PK
        string name UK
        int capacity
        enum zone "SALON | TERRAZA | VIP | BARRA | PISTA"
        int floor "1 o 2"
        int posX
        int posY
        boolean isActive
    }

    Reservation {
        uuid id PK
        string customerName
        string customerPhone
        date reservationDate
        string reservationTime
        int partySize
        string message
        enum status "PENDING | CONFIRMED | CANCELLED | COMPLETED"
        uuid tableId FK
    }

    Customer {
        uuid id PK
        string name
        string phone UK
        date birthDate
        int rating "1-5"
        enum source "QR_SCAN | RESERVATION | MANUAL"
        int totalVisits
        datetime lastVisitAt
        boolean optIn
        boolean isActive
    }

    WhatsAppMessage {
        uuid id PK
        uuid customerId FK
        enum type "WELCOME | BIRTHDAY | PROMO | SURVEY"
        string templateName
        enum status "QUEUED | SENT | DELIVERED | READ | FAILED"
        string waMessageId
        datetime sentAt
    }

    SatisfactionSurvey {
        uuid id PK
        uuid customerId FK
        int musicRating "1-5"
        int serviceRating "1-5"
        int ambienceRating "1-5"
        int hygieneRating "1-5"
        string qrTable
    }
```

Adicionalmente: `RefreshToken`, `TokenBlacklist`, `Interaction` (historial de acciones), `CrmConfig` (configuración dinámica).

