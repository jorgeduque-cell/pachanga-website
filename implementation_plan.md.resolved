### Componente: Prisma Schema (TSK-02)

#### [NEW] [schema.prisma](file:///c:/Users/LENOVO%20CORP/Proyecto%20Pachanga/backend/prisma/schema.prisma)

```prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum TableZone {
  SALON
  TERRAZA
  VIP
  BARRA
  PISTA
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Table {
  id           String      @id @default(uuid())
  name         String      @unique
  capacity     Int
  zone         TableZone
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  reservations Reservation[]

  @@map("tables")
}

model Reservation {
  id              String            @id @default(uuid())
  customerName    String            @map("customer_name")
  customerPhone   String            @map("customer_phone")
  reservationDate DateTime          @map("reservation_date") @db.Date
  reservationTime String            @map("reservation_time")
  partySize       Int               @map("party_size")
  message         String?
  status          ReservationStatus @default(PENDING)
  tableId         String?           @map("table_id")
  table           Table?            @relation(fields: [tableId], references: [id])
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([reservationDate, status])
  @@index([tableId, reservationDate])
  @@map("reservations")
}
```

